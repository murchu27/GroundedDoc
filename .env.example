# Optional: required for Gemini-powered synthesis and ADK web UI
GOOGLE_API_KEY=

# GroundedDoc paths
GROUNDED_DATA_DIR=
GROUNDED_CORPUS_DIR=
GROUNDED_INDEX_DIR=
MLFLOW_TRACKING_URI=
MLFLOW_EXPERIMENT=grounded-doc-agent

# Cloud Run optional auth (clients send GROUNDED_API_KEY via X-API-Key header)
GROUNDED_REQUIRE_API_KEY=false
GROUNDED_API_KEY=

# Browser extension / analyze API
GROUNDED_CORS_ORIGINS=*

# Optional GCS persistence (install with: pip install '.[gcp]')
GROUNDED_STORAGE_BACKEND=local
GROUNDED_GCS_BUCKET=
GROUNDED_SKIP_STORAGE_SYNC=false
